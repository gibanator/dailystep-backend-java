# Database (local Spring Boot)
DB_URL=jdbc:postgresql://localhost:5432/db_name
DB_USER=uname
DB_PASSWORD=password

# Docker Postgres
POSTGRES_DB=db_name
POSTGRES_USER=uname
POSTGRES_PASSWORD=password

# GigaChat (Sber) — https://developers.sber.ru/portal/products/gigachat-api
# Authorization key (base64 от client_id:client_secret) из личного кабинета GigaChat API
GIGACHAT_API_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# dev: true пропускает проверку TLS-сертификата. В проде — false + сертификаты Минцифры.
GIGACHAT_UNSAFE_SSL=true
GIGACHAT_MODEL=GigaChat